generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  pending
  accepted
}

enum UserRole {
  OWNER
  ADMIN
  MODERATOR
  SUPPORT
  USER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ANSWERED
  CLOSED
}

model User {
  id                  String       @id @default(cuid())
  username            String       @unique
  passwordHash        String
  role                UserRole     @default(USER)
  clanTag             String?      @map("clan_tag")
  isBanned            Boolean      @default(false) @map("is_banned")
  avatarUrl           String?      @map("avatar_url")
  bannerUrl           String?      @map("banner_url")
  bio                 String?      @map("bio")
  chatColor           String?      @map("chat_color")
  balance             String       @default("10000.00")
  xp                  Int          @default(0)
  dailyStatsDate      String       @default("") @map("daily_stats_date")
  dailyBets           Int          @default(0) @map("daily_bets")
  dailyWins           Int          @default(0) @map("daily_wins")
  dailyFaucetClaimed  Boolean      @default(false) @map("daily_faucet_claimed")
  dailyQuestClaimed   Boolean      @default(false) @map("daily_quest_claimed")
  createdAt           DateTime     @default(now())
  settings            Settings?
  friendshipsSent     Friendship[] @relation("FriendshipsSent")
  friendshipsReceived Friendship[] @relation("FriendshipsReceived")
  blocksSent          Block[]      @relation("BlocksSent")
  blocksReceived      Block[]      @relation("BlocksReceived")
  transactionsSent    Transaction[] @relation("TransactionsSent")
  transactionsReceived Transaction[] @relation("TransactionsReceived")
  tickets             Ticket[]
  ticketMessagesSent  TicketMessage[] @relation("TicketMessagesSent")

  @@map("users")
}

model Block {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  blockedUserId String   @map("blocked_user_id")
  createdAt     DateTime @default(now())

  user        User @relation("BlocksSent", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser User @relation("BlocksReceived", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([blockedUserId])
  @@map("blocks")
}

model Friendship {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  friendId  String           @map("friend_id")
  status    FriendshipStatus @default(pending)
  createdAt DateTime         @default(now())

  user   User @relation("FriendshipsSent", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipsReceived", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([friendId])
  @@map("friendships")
}

model Settings {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  soundEnabled Boolean  @default(true)
  theme        String   @default("slate")
  selectedRankTag String @default("BRONZE") @map("selected_rank_tag")
  publicProfile Boolean @default(true) @map("public_profile")
  bio          String   @default("")
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model QuestProgress {
  userId            String   @id @map("user_id")
  dailyDate         String   @map("daily_date")
  dailySlotsRounds  Int      @default(0) @map("daily_slots_rounds")
  dailyClaimed      Int      @default(0) @map("daily_claimed")
  weeklyDate        String   @map("weekly_date")
  weeklySlotsRounds Int      @default(0) @map("weekly_slots_rounds")
  weeklyBetActions  Int      @default(0) @map("weekly_bet_actions")
  weeklyWinActions  Int      @default(0) @map("weekly_win_actions")
  weeklyClaimed     Int      @default(0) @map("weekly_claimed")
  updatedAt         String   @default("") @map("updated_at")

  @@map("quest_progress")
}

model Transaction {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  amount     String
  message    String   @default("")
  createdAt  DateTime @default(now())

  sender   User @relation("TransactionsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("TransactionsReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@map("transactions")
}

model Ticket {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  subject   String
  category  String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id           String   @id @default(uuid())
  ticketId     String   @map("ticket_id")
  senderId     String   @map("sender_id")
  content      String
  isStaffReply Boolean  @default(false) @map("is_staff_reply")
  createdAt    DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation("TicketMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@map("ticket_messages")
}
