{
  "name": "neon-vault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "free-port:web": "sh -c 'pids=$(lsof -ti tcp:3000 2>/dev/null || true); if [ -n \"$pids\" ]; then kill -9 $pids; fi'",
    "free-port:game": "sh -c 'pids=$(lsof -ti tcp:4001 2>/dev/null || true); if [ -n \"$pids\" ]; then kill -9 $pids; fi'",
    "predev": "npm run free-port:web",
    "predev:game-server": "npm run free-port:game",
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:lan": "npm run dev",
    "dev:game-server": "cd game-server && HOST=0.0.0.0 npm run dev",
    "dev:game-server:lan": "npm run dev:game-server",
    "dev:all": "sh -c 'npm run dev & web=$!; npm run dev:game-server & game=$!; trap \"kill $web $game\" INT TERM EXIT; wait'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy:up": "docker compose -f docker-compose.deploy.yml up -d --build",
    "deploy:down": "docker compose -f docker-compose.deploy.yml down",
    "deploy:logs": "docker compose -f docker-compose.deploy.yml logs -f",
    "tunnel": "sh ./tunnel-tailscale.sh",
    "tunnel:dev": "sh -c 'npm run dev:all & sleep 3 && npm run tunnel'",
    "tunnel:stop": "sh ./tunnel-tailscale-stop.sh",
    "tunnel:url": "sh ./tunnel-url.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.29",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
