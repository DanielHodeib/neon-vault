{
  "name": "neon-vault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:game-server": "cd game-server && npm run dev",
    "dev:game-server:lan": "cd game-server && HOST=0.0.0.0 npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy:up": "docker compose -f docker-compose.deploy.yml up -d --build",
    "deploy:down": "docker compose -f docker-compose.deploy.yml down",
    "deploy:logs": "docker compose -f docker-compose.deploy.yml logs -f"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.29",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
