{
  "name": "neon-vault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && next build",
    "prebuild": "npm run check:production-readiness",
    "check:production-readiness": "prisma generate && npm run check:types && npm run check:viprank && npm run check:frontend-api",
    "check:types": "tsc --noEmit",
    "check:viprank": "node scripts/validate-viprank-export.js",
    "check:frontend-api": "node scripts/validate-frontend-api-url.js",
    "db:ui": "prisma studio",
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:all": "sh -c 'npm run dev & web=$!; (cd game-server && npm run dev) & game=$!; trap \"kill $web $game\" INT TERM EXIT; wait'",
    "restart:all": "sh -c 'web=$(lsof -ti tcp:3000 2>/dev/null || true); game=$(lsof -ti tcp:5000 2>/dev/null || true); [ -n \"$web\" ] && kill -9 $web || true; [ -n \"$game\" ] && kill -9 $game || true; npm run dev:all'",
    "start": "next start",
    "tunnel": "sh ./tunnel-tailscale.sh",
    "tunnel:stop": "sh ./tunnel-tailscale-stop.sh",
    "tunnel:url": "sh ./tunnel-url.sh",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@prisma/client": "^6.5.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.29",
    "prisma": "^6.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.80.0"
  }
}
